{
  "expo": {
    "name": "LedgerFinance",
    "slug": "frontend_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ledger",
    "icon": "./assets/ledgerlogo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/ledgerlogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/ledgerlogo.png",
        "backgroundImage": "./assets/ledgerlogo.png",
        "monochromeImage": "./assets/ledgerlogo.png"
      },
      "package": "com.ledgerfinance.app",
      "permissions": [
        "RECEIVE_SMS",
        "READ_SMS"
      ]
    },
    "web": {
      "favicon": "./assets/ledgerlogo.png"
    },
    "plugins": [
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/ledgerlogo.png",
          "color": "#1E6BD6"
        }
      ],
      "./plugins/withSmsAndroidPatch.js"
    ],
    "extra": {
      "eas": {
        "projectId": "9b4d3c9f-432f-4b1a-a77a-aaeab3d50ee5"
      }
    }
  }
}